# Secured Moveworks Webhook Listener used by the dashboard Run/Test/AI trigger.
MOVEWORKS_TRIGGER_URL=

# Read-only governance snapshot. Prefer this single aggregated endpoint when available.
MOVEWORKS_DASHBOARD_URL=

# Or use split read-only endpoints instead of MOVEWORKS_DASHBOARD_URL.
MOVEWORKS_AGEING_URL=
MOVEWORKS_SLA_URL=
MOVEWORKS_DEVOPS_URL=

# AI prompt endpoint accepting {prompt,user_email,context}.
MOVEWORKS_AI_URL=

# Optional dashboard actions.
MOVEWORKS_ASSIGN_URL=
MOVEWORKS_NOTIFY_URL=
MOVEWORKS_EOD_URL=

# Authentication used by the App Service backend when calling Moveworks.
MOVEWORKS_AUTH_TOKEN=
# Moveworks API key credential. Sent as Authorization: Bearer <key>.
MOVEWORKS_API_KEY=
MOVEWORKS_TENANT_ID=
DEFAULT_NOTIFICATION_EMAIL=
UPSTREAM_TIMEOUT_MS=25000



# Optional but recommended on Azure App Service so Moveworks receives an HTTPS callback URL.
PUBLIC_BASE_URL=https://YOUR-APP.azurewebsites.net
# Optional callback shared secret. Leave unset for the hackathon demo.
MOVEWORKS_CALLBACK_SECRET=
